# Copy this file to .env and fill in your values
# cp .env.example .env

# Session secret (any long random string, e.g. use: openssl rand -hex 32)
SECRET=your_session_secret_here

# Cloudinary credentials — get from cloudinary.com > Dashboard
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_api_key
CLOUD_API_SECRET=your_api_secret

# MongoDB Atlas connection string — get from cloud.mongodb.com > Connect > Drivers
ATLAS_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/WanderLust?retryWrites=true&w=majority
