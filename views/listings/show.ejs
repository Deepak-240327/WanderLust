<% layout("/layouts/boilerplate.ejs") %>
<body>
    <h3><%= list.title %></h3>
    <div class="row">
        <div class="col-8 offset-2">
            <div class="showcard">
                <img src="<%= list.image && list.image.url ? list.image.url : 'https://images.unsplash.com/photo-1625505826533-5c80aca7d157?auto=format&fit=crop&w=800&q=60' %>" class="showimg" alt="<%= list.image && list.image.filename ? list.image.filename : 'Listing Image' %>">
                <div class="card-body">
                    <p class="card-text"><%= list.description %></p>
                    <p><b><%= list.location %>, <%= list.country %></b></p>
                    <p><i class="fa-solid fa-indian-rupee-sign"></i><b><%=list.price.toLocaleString("en-IN")%></b></p>
                     <% if(currUser && currUser._id.equals(list.owner._id)){ %>
                    <div class="btns">
                        <form method="get" action="/listings/<%=list._id%>/edit">
                            <button class="btn btn-lg showbtn">Edit</button>
                        </form>
                        <form method="post" action="/listings/<%=list._id%>?_method=Delete">
                            <button class="btn btn-lg showbtn">Delete</button>
                        </form>
                    </div>
                   <%  } %>
                </div>
            </div>
        </div>
        <hr/>
        <div class="col-8 offset-2 mb-3">
            <h4>Leave a Review</h4>
            <form method="post" action="/listings/<%=list._id%>/reviews" class="needs-validation" novalidate>
                <div>
                    <legend>Rating:</legend>
                    <fieldset class="starability-basic">
                    <input type="radio" id="first-rate1" name="review[rating]" value="1" checked />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>         
                </div>
                <div>
                    <label for="comment" class="form-label">Comment</label><br>
                    <textarea rows="5" cols="80" placeholder="Please comment" id="comment" name="review[comment]" class="form-control" required></textarea>
                    <div class="invalid-feedback">Please add some comment</div>
                </div>
                <br/>
                <button class="btn btn-outline-dark">Submit</button>
            </form>
        </div>
        <hr/>
    </div>
        <div class="row">
            <h4>Reviews</h4>
            <% for(review of list.review) { %>
                <div class="card col-5 ms-2 mb-3">
                    <div class="card-body">
                        <h5 class="card-title"><%= review.author.username %></h5>
                        <p class="starability-result" data-rating="<%= review.rating %>"></p>
                        <p class="card-text"><%= review.comment %></p>
                    </div>
                    <% if(currUser && currUser._id.equals(review.author._id)) {%>
                    <div class="mb-3 mt-2">
                        <form method="post" action="/listings/<%= list._id %>/reviews/<%= review._id %>?_method=Delete">
                            <button class="btn btn-sm btn-dark">Delete</button>
                        </form>
                    </div>
                    <% } %>
                </div>
             <% } %>
        </div> 
    
</body>


    